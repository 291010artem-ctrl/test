# ── Required ────────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=

# ── Recommended ─────────────────────────────────────────────────────────────
# Free TonAPI key from https://tonconsole.com — raises rate limits a lot.
# Without it the public tonapi.io tier still works but is rate-limited.
TONAPI_KEY=

# Optional GetGems API key (GetGems is used best-effort; works without a key too)
GETGEMS_API_KEY=

# ── Advanced (defaults are fine, uncomment to override) ──────────────────────
# TONAPI_BASE=https://tonapi.io
# GETGEMS_ENDPOINT=https://api.getgems.io/graphql
# FRAGMENT_BASE=https://fragment.com
# Telegram Usernames NFT collection on TON
# USERNAMES_COLLECTION=EQCA14o1-VWhS2efqoh_9M1b_A9DtKTuoqfmkn83AbJzwnPi
# REQUEST_TIMEOUT=15
# CACHE_TTL=120
# LOG_LEVEL=INFO
