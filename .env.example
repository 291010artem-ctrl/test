# Telegram Bot API token from @BotFather
BOT_TOKEN=

# --- Marketplace auth (optional, fill in as you obtain them) ---
# Tonnel: value of "web-initData" from market.tonnel.network LocalStorage
TONNEL_INIT_DATA=

# Portals: "tma {token}" auth value, rotates every 1-7 days
PORTALS_AUTH_TOKEN=

# mrkt (tgmrkt): bearer token obtained via POST /auth with Telegram initData
MRKT_BEARER_TOKEN=
